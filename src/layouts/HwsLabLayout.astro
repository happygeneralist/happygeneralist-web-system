---
import HwsBaseLayout from './HwsBaseLayout.astro'

interface Props {
  title: string
  description: string
  eyebrow?: string
  themes?: string[]
}

const { title, description, eyebrow = 'Lab', themes = [] } = Astro.props
---

<HwsBaseLayout title={title} description={description}>
  <article class="hws-lab-shell">
    <header class="hws-page-header hws-prose">
      <p class="hws-meta">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{description}</p>
      {themes.length > 0 && (
        <ul class="hws-tag-list" aria-label="Themes">
          {themes.map((theme) => <li class="hws-tag">{theme}</li>)}
        </ul>
      )}
    </header>
    <div class="hws-lab-grid">
      <slot />
    </div>
  </article>
</HwsBaseLayout>
