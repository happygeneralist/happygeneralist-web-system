---
import '../styles/system.css'

interface NavItem {
  href: string
  label: string
}

interface Props {
  title: string
  description?: string
  navItems?: NavItem[]
  siteName?: string
}

const {
  title,
  description = 'A clear, accessible Astro site using Happygeneralist web system foundations.',
  navItems = [],
  siteName = 'Happygeneralist web system'
} = Astro.props
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <a class="hws-skip-link" href="#main-content">Skip to main content</a>
    <header class="hws-container" style="padding-block: var(--hws-space-4); border-bottom: 1px solid var(--hws-colour-border);">
      <a href="/" style="font-weight: 700; color: var(--hws-colour-text); text-decoration: none;">{siteName}</a>
      {navItems.length > 0 && (
        <nav aria-label="Main navigation" style="display: flex; flex-wrap: wrap; gap: var(--hws-space-4); margin-top: var(--hws-space-3);">
          {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      )}
    </header>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
